{
  "version": 1,
  "doc": "宏观序列抓取配置。业务含义、更新频率见 factors/macro/README.md。时间序列落地：data/macro/series/",
  "lookback_years": 5,
  "output_dir": "data/macro/series",
  "series": [
    {
      "id": "us_fed_funds_effective",
      "source": "fred",
      "fred_id": "DFF",
      "frequency": "daily",
      "description": "Effective Federal Funds Rate"
    },
    {
      "id": "us_treasury_10y_yield",
      "source": "fred",
      "fred_id": "DGS10",
      "frequency": "daily",
      "description": "10-Year Treasury Constant Maturity Rate (%)"
    },
    {
      "id": "us_fed_funds_target_mid",
      "source": "fred_target_mid",
      "fred_low": "DFEDTARL",
      "fred_high": "DFEDTARU",
      "frequency": "daily",
      "description": "Fed funds target range midpoint (DFEDTARL+DFEDTARU)/2"
    },
    {
      "id": "us_pce_core_yoy",
      "source": "fred_yoy_index",
      "fred_id": "PCEPILFE",
      "frequency": "monthly",
      "description": "Core PCE price index YoY % (from monthly index level)"
    },
    {
      "id": "us_pce_headline_yoy",
      "source": "fred_yoy_index",
      "fred_id": "PCEPI",
      "frequency": "monthly",
      "description": "Headline PCE price index YoY %"
    },
    {
      "id": "cn_lpr_1y",
      "source": "akshare_lpr",
      "lpr_term": "1y",
      "frequency": "monthly",
      "description": "中国 1 年期 LPR"
    },
    {
      "id": "cn_lpr_5y",
      "source": "akshare_lpr",
      "lpr_term": "5y",
      "frequency": "monthly",
      "description": "中国 5 年期 LPR"
    },
    {
      "id": "cn_government_bond_10y_yield",
      "source": "akshare_bond_zh_us",
      "frequency": "daily",
      "description": "中国 10 年期国债收益率（akshare bond_zh_us_rate 列）"
    },
    {
      "id": "cn_cpi_core_yoy",
      "source": "akshare_cpi_yoy",
      "frequency": "monthly",
      "description": "中国 CPI 同比（全国商品及服务类同比，以 akshare 返回为准）"
    }
  ]
}
